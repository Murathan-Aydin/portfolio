# --- Informations personnelles ---
BUSINESS_NAME=
FIRST_NAME=
LAST_NAME=
SIRET=
ADDRESS=

# --- Contact ---
CONTACT_EMAIL=
PHONE_NUMBER=
PHONE_NUMBER_DISPLAY=

# --- Hébergeur (pour mentions légales) ---
